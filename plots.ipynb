      "source": [
        "import numpy as np\n",
        "import matplotlib.pyplot as plt\n",
        "from transformers import AutoModel, AutoTokenizer\n",
        "import torch\n",
        "from sklearn.metrics.pairwise import cosine_similarity\n",
        "from scipy.spatial.distance import euclidean\n",
        "\n",
        "bert = AutoModel.from_pretrained(\"bert-large-uncased\")\n",
        "monobert = AutoModel.from_pretrained(\"castorini/monobert-large-msmarco\")\n",
        "tokenizer = AutoTokenizer.from_pretrained(\"bert-large-uncased\")\n",
        "\n",
        "bert_params = dict(bert.named_parameters())\n",
        "monobert_params = dict(monobert.named_parameters())\n",
        "\n",
        "dense_frob, dense_max, dense_idx = [], [], []\n",
        "attn_frob, attn_max, attn_idx = [], [], []\n",
        "emb_frob, emb_max, emb_idx = [], [], []\n",
        "\n",
        "for name, param_mono in monobert_params.items():\n",
        "    if name not in bert_params:\n",
        "        continue\n",
        "    param_bert = bert_params[name]\n",
        "    if param_bert.shape != param_mono.shape:\n",
        "        continue\n",
        "\n",
        "    diff = (param_mono - param_bert).detach().float()\n",
        "    frob = torch.norm(diff, p=\"fro\").item()\n",
        "    mx = torch.max(torch.abs(diff)).item()\n",
        "\n",
        "    parts = name.split(\".\")\n",
        "    layer_num = -1\n",
        "    for i, p in enumerate(parts):\n",
        "        if p == \"layer\" and i + 1 < len(parts):\n",
        "            try:\n",
        "                layer_num = int(parts[i + 1])\n",
        "            except ValueError:\n",
        "                pass\n",
        "\n",
        "    if \"embedding\" in name:\n",
        "        emb_frob.append(frob)\n",
        "        emb_max.append(mx)\n",
        "        emb_idx.append(layer_num)\n",
        "    elif \"attention\" in name:\n",
        "        attn_frob.append(frob)\n",
        "        attn_max.append(mx)\n",
        "        attn_idx.append(layer_num)\n",
        "    else:\n",
        "        dense_frob.append(frob)\n",
        "        dense_max.append(mx)\n",
        "        dense_idx.append(layer_num)\n",
        "\n",
        "c_dense = \"#e63946\"\n",
        "c_attn  = \"#2a9d8f\"\n",
        "c_emb   = \"#264653\"\n",
        "\n",
        "fig, axes = plt.subplots(1, 2, figsize=(12, 5))\n",
        "\n",
        "ax = axes[0]\n",
        "ax.scatter(dense_idx, dense_max, color=c_dense, s=20, label=\"Dense Weight\")\n",
        "ax.scatter(attn_idx, attn_max, color=c_attn, s=20, label=\"Attention Weight\")\n",
        "ax.scatter(emb_idx, emb_max, color=c_emb, s=30, label=\"Embeddings Weight\")\n",
        "ax.set_xlabel(\"Layer number\")\n",
        "ax.set_ylabel(r\"Max norm $\\|\\Delta\\theta\\|_{max}$\")\n",
        "ax.legend(loc=\"upper left\", fontsize=8)\n",
        "\n",
        "ax = axes[1]\n",
        "ax.scatter(dense_idx, dense_frob, color=c_dense, s=20, label=\"Dense Weight\")\n",
        "ax.scatter(attn_idx, attn_frob, color=c_attn, s=20, label=\"Attention Weight\")\n",
        "ax.scatter(emb_idx, emb_frob, color=c_emb, s=30, label=\"Embeddings Weight\")\n",
        "ax.set_xlabel(\"Layer number\")\n",
        "ax.set_ylabel(r\"Frobenius norm $\\|\\Delta\\theta\\|_F$\")\n",
        "ax.legend(loc=\"upper left\", fontsize=8)\n",
        "\n",
        "plt.suptitle(\"Weight differences between BERT and monoBERT per layer\", fontsize=11)\n",
        "plt.tight_layout()\n",
        "plt.savefig(\"plot1_norms.png\", dpi=150)\n",
        "plt.show()\n",
        "plt.close()\n",
        "\n",
        "bert_emb = bert.embeddings.word_embeddings.weight.detach().float().numpy()\n",
        "monobert_emb = monobert.embeddings.word_embeddings.weight.detach().float().numpy()\n",
        "\n",
        "n = min(bert_emb.shape[0], monobert_emb.shape[0])\n",
        "bert_emb = bert_emb[:n]\n",
        "monobert_emb = monobert_emb[:n]\n",
        "\n",
        "cos_sim = np.array([\n",
        "    cosine_similarity(bert_emb[i].reshape(1, -1), monobert_emb[i].reshape(1, -1))[0, 0]\n",
        "    for i in range(n)\n",
        "])\n",
        "\n",
        "euc_dist = np.array([\n",
        "    euclidean(bert_emb[i], monobert_emb[i])\n",
        "    for i in range(n)\n",
        "])\n",
        "\n",
        "interesting_tokens = {\n",
        "    tokenizer.convert_tokens_to_ids(\"document\"): \"Document\",\n",
        "    tokenizer.convert_tokens_to_ids(\"query\"): \"Query\",\n",
        "    tokenizer.convert_tokens_to_ids(\"true\"): \"true\",\n",
        "    tokenizer.convert_tokens_to_ids(\"false\"): \"false\",\n",
        "    tokenizer.convert_tokens_to_ids(\"relevant\"): \"Relevant\",\n",
        "    tokenizer.convert_tokens_to_ids(\":\"): \"Colon :\",\n",
        "    tokenizer.sep_token_id: \"SEP\",\n",
        "}\n",
        "\n",
        "label_offsets = {\n",
        "    \"Document\":  (-0.004,  0.012),\n",
        "    \"Query\":     (-0.004,  0.020),\n",
        "    \"true\":      (-0.004, -0.010),\n",
        "    \"false\":     ( 0.001,  0.016),\n",
        "    \"Relevant\":  ( 0.001,  0.008),\n",
        "    \"Colon :\":   (-0.004, -0.018),\n",
        "    \"SEP\":       ( 0.001, -0.010),\n",
        "}\n",
        "\n",
        "c_cloud     = \"#4a90d9\"\n",
        "c_highlight = \"#43b97f\"\n",
        "\n",
        "fig, axes = plt.subplots(1, 2, figsize=(14, 5))\n",
        "\n",
        "ax = axes[0]\n",
        "ax.scatter(cos_sim, euc_dist, s=10, alpha=0.4, color=c_cloud)\n",
        "for token_id, label in interesting_tokens.items():\n",
        "    if token_id is not None and token_id < n:\n",
        "        ax.scatter(cos_sim[token_id], euc_dist[token_id], color=c_highlight, s=40, zorder=5)\n",
        "ax.set_xlabel(\"Cosine similarity\")\n",
        "ax.set_ylabel(\"Euclidean distance\")\n",
        "ax.set_title(\"Full range\", fontsize=10)\n",
        "\n",
        "ax = axes[1]\n",
        "ax.scatter(cos_sim, euc_dist, s=10, alpha=0.4, color=c_cloud)\n",
        "for token_id, label in interesting_tokens.items():\n",
        "    if token_id is not None and token_id < n:\n",
        "        x, y = cos_sim[token_id], euc_dist[token_id]\n",
        "        dx, dy = label_offsets.get(label, (-0.002, 0.008))\n",
        "        ax.scatter(x, y, color=c_highlight, s=40, zorder=5)\n",
        "        ax.annotate(\n",
        "            label,\n",
        "            xy=(x, y),\n",
        "            xytext=(x + dx, y + dy),\n",
        "            fontsize=8,\n",
        "            arrowprops=dict(arrowstyle=\"->\", lw=0.8),\n",
        "        )\n",
        "ax.set_xlim(0.970, 1.001)\n",
        "ax.set_ylim(0.00, 0.25)\n",
        "ax.set_xlabel(\"Cosine similarity\")\n",
        "ax.set_ylabel(\"Euclidean distance\")\n",
        "ax.set_title(\"Zoomed: high similarity region\", fontsize=10)\n",
        "\n",
        "plt.suptitle(\"Per-token embedding shift: BERT vs monoBERT\", fontsize=11)\n",
        "plt.tight_layout()\n",
        "plt.savefig(\"plot2_embeddings.png\", dpi=150)\n",
        "plt.show()\n",
        "plt.close()"
      ]
    }
  ],
